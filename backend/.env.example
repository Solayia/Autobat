# ============================================================
# AUTOBAT - Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer .env en production
# ============================================================

# ------------------------------------------------------------
# BASE DE DONNÉES
# ------------------------------------------------------------
# Dev local SQLite (schema.sqlite.prisma) :
# DATABASE_URL="file:./dev.db"
# Production PostgreSQL :
DATABASE_URL="postgresql://autobat:MOTDEPASSE_DB@localhost:5432/autobat_prod"

# ------------------------------------------------------------
# JWT (générer avec : openssl rand -hex 32)
# ------------------------------------------------------------
JWT_SECRET=REMPLACER_PAR_64_CARACTERES_ALEATOIRES
JWT_REFRESH_SECRET=REMPLACER_PAR_64_AUTRES_CARACTERES_ALEATOIRES
JWT_ACCESS_EXPIRATION="24h"
JWT_REFRESH_EXPIRATION="7d"

# ------------------------------------------------------------
# SERVEUR
# ------------------------------------------------------------
PORT=3000
NODE_ENV="production"

# ------------------------------------------------------------
# CORS & FRONTEND
# ------------------------------------------------------------
CORS_ORIGIN="https://app.autobat.fr"
FRONTEND_URL="https://app.autobat.fr"

# ------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------------------------
# STRIPE (https://dashboard.stripe.com/apikeys)
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_live_REMPLACER
STRIPE_WEBHOOK_SECRET=whsec_REMPLACER
STRIPE_PRICE_ADMIN=price_REMPLACER
STRIPE_PRICE_EMPLOYE=price_REMPLACER

# ------------------------------------------------------------
# UPLOADS (chemin absolu sur le serveur)
# ------------------------------------------------------------
UPLOAD_DIR=/var/www/autobat/uploads
UPLOAD_MAX_SIZE_MB=10
